# Copy to `.env` in this folder. Restart Metro with cache clear: `npx expo start -c`
#
# Physical device (Expo Go): use your computer's LAN IP, not localhost.
#   Mac (Wi‑Fi): ipconfig getifaddr en0
#   Same Wi‑Fi as the phone; backend must listen on all interfaces:
#   uvicorn app.main:app --host 0.0.0.0 --port 8000
#
# Omit EXPO_PUBLIC_API_URL to use defaults: iOS Simulator / web → localhost:8000;
# Android Emulator → 10.0.2.2:8000
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8000

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
